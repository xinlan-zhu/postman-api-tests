    {
      "name": "setup dda",
      "event": [
        {
          "listen": "prerequest",
          "script": {
            "exec": [
              "// 1. 生成唯一的 boTransactionReferenceNo\r",
              "const timestamp = Date.now();              // 毫秒时间戳\r",
              "const randomNum = Math.floor(Math.random() * 10000); // 0-9999 随机数\r",
              "const uniqueRefNo = `${timestamp}${randomNum}`;\r",
              "\r",
              "// 2. 获取当天日期，格式：DD-MM-YYYY\r",
              "const today = new Date();\r",
              "const day = String(today.getDate()).padStart(2, '0');\r",
              "const month = String(today.getMonth() + 1).padStart(2, '0'); // 月份从0开始\r",
              "const year = today.getFullYear();\r",
              "const currentDate = `${day}-${month}-${year}`;\r",
              "\r",
              "// 3. 设置为环境变量\r",
              "pm.environment.set(\"dynamic_boTransactionReferenceNo\", uniqueRefNo);\r",
              "pm.environment.set(\"dynamic_fromDate\", currentDate);\r",
              "pm.environment.set(\"dynamic_toDate\", currentDate);\r",
              "\r",
              "// 可选：控制台打印验证\r",
              "console.log(\"Generated boTransactionReferenceNo:\", uniqueRefNo);\r",
              "console.log(\"Generated fromDate:\", currentDate);\r",
              "console.log(\"Generated toDate:\", currentDate);"
            ],
            "type": "text/javascript",
            "packages": {},
            "requests": {}
          }
        },
        {
          "listen": "test",
          "script": {
            "exec": [
              "const res = pm.response.json();\r",
              "const expectedRqUID = pm.variables.get(\"expectedRqUID\") || \"BO\";\r",
              "const expectedReturnCode = pm.variables.get(\"expectedReturnCode\") || \"UX0000\";\r",
              "const expectedReturnStatus = pm.variables.get(\"expectedReturnStatus\") || \"Successful\";\r",
              "\r",
              "pm.test(\"rqUID 返回正确\", () => {\r",
              "    pm.expect(res.rqUID).to.equal(expectedRqUID);\r",
              "});\r",
              "\r",
              "pm.test(\"returnCode 返回正确\", () => {\r",
              "    pm.expect(res.returnCode).to.equal(expectedReturnCode);\r",
              "});\r",
              "\r",
              "pm.test(\"returnStatus 返回正确\", () => {\r",
